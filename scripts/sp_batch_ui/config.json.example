{
  "host": "0.0.0.0",
  "port": 18792,
  "env": "uat",
  "_comment_streampark": "凭据从 ../../config.ini [env:<env>] 加载，本文件中 streampark 仅放非凭据配置",
  "streampark": {
    "default_app_id": ""
  },
  "mongo": {
    "uri": "mongodb://USER:PASS@HOST:27017/?replicaSet=RS&authSource=admin&authMechanism=SCRAM-SHA-1&maxIdleTimeMS=120000&socketTimeoutMS=600000",
    "db": "magnolia_prod",
    "collection_pattern": "event_data_{ymd}"
  },
  "doris": {
    "host": "REPLACE_ME",
    "port": 9030,
    "user": "REPLACE_ME",
    "password": "REPLACE_ME",
    "table": "uat_prod_ods_mongo_magnolia.event_data",
    "date_column": "shard_date",
    "partition_pattern": "p{ymd}"
  },
  "window_timeout_seconds": 5400
}
